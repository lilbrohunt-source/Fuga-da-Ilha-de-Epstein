    }
}

const jsStick = document.getElementById('joystick-stick');
const jsBoundary = document.getElementById('joystick-boundary');

if (jsBoundary) {
    jsBoundary.addEventListener('touchstart', (e) => {
        e.preventDefault();
        const touch = e.changedTouches[0];
        const rect = jsBoundary.getBoundingClientRect();
        
        joystick.active = true;
        joystick.touchId = touch.identifier;
        joystick.startX = rect.left + rect.width / 2;
        joystick.startY = rect.top + rect.height / 2;
    }, { passive: false });

    window.addEventListener('touchmove', (e) => {
        if (!joystick.active) return;
        
        let targetTouch = null;
        for (let i = 0; i < e.touches.length; i++) {
            if (e.touches[i].identifier === joystick.touchId) {
                targetTouch = e.touches[i];
                break;
            }
        }
        
        if (!targetTouch) return;
        
        let dx = targetTouch.clientX - joystick.startX;
        let dy = targetTouch.clientY - joystick.startY;
        let dist = Math.sqrt(dx*dx + dy*dy);

        if (dist > joystick.maxDistance) {
            dx = (dx / dist) * joystick.maxDistance;
            dy = (dy / dist) * joystick.maxDistance;
            dist = joystick.maxDistance;
        }

        jsStick.style.transform = `translate(${dx}px, ${dy}px)`;

        joystick.vx = dx / joystick.maxDistance;
        joystick.vy = dy / joystick.maxDistance;
    }, { passive: false });

    window.addEventListener('touchend', (e) => {
        if (!joystick.active) return;
        
        let stillActive = false;
        for (let i = 0; i < e.touches.length; i++) {
            if (e.touches[i].identifier === joystick.touchId) {
                stillActive = true;
            }
        }
        
        if (!stillActive) {
            joystick.active = false;
            joystick.touchId = null;
            joystick.vx = 0;
            joystick.vy = 0;
            jsStick.style.transform = 'translate(0px, 0px)';
        }
    }, { passive: false });
}

class FlyingStone {
    constructor(startX, startY, targetX, targetY) {
        this.startX = startX; this.startY = startY;
        this.targetX = targetX; this.targetY = targetY;
        this.x = startX; this.y = startY;
        this.progress = 0;
        this.speed = 0.04; 
    }
    update() {
        this.progress += this.speed;
        if (this.progress >= 1) {
            this.progress = 1;
            this.x = this.targetX;
            this.y = this.targetY;
            return true; 
        }
        this.x = this.startX + (this.targetX - this.startX) * this.progress;
        this.y = this.startY + (this.targetY - this.startY) * this.progress;
        return false;
    }
    draw() {
        let height = Math.sin(this.progress * Math.PI) * 15;
        let size = 3 + height * 0.25;

        ctx.save();
        ctx.shadowColor = 'rgba(0, 0, 0, 0.6)';
        ctx.shadowBlur = 8;
        ctx.fillStyle = '#71717a';
        ctx.beginPath();
        ctx.arc(this.x, this.y - height, size, 0, Math.PI*2);
        ctx.fill();
        ctx.restore();
    }
}

function throwStoneAt(targetX, targetY) {
    if (player.rockCount > 0) {
        player.rockCount--;
        updateInventoryUI();
        flyingStones.push(new FlyingStone(player.x, player.y, targetX, targetY));
        
        // Co-Op: Sincroniza o arremesso de pedra na rede
        publishStoneAction(player.x, player.y, targetX, targetY);
    }
}

