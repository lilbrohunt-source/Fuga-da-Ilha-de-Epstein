<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Fuga de Little St. James - Ultimate Co-Op Stealth</title>
    <!-- Tailwind CSS para design ágil e responsivo -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts para tipografia clássica militar/retro -->
    <link href="https://fonts.googleapis.com/css2?family=Courier+Prime:wght@400;700&family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <!-- Ícones FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Biblioteca MQTT para Multiplayer Instantâneo sem chaves externas -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/mqtt/4.3.7/mqtt.min.js"></script>
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #010102;
            overflow: hidden;
            user-select: none;
            touch-action: none;
            -webkit-user-select: none;
        }
        .retro-font {
            font-family: 'Courier Prime', monospace;
        }
        .scanlines {
            position: relative;
            overflow: hidden;
        }
        .scanlines::before {
            content: " ";
            display: block;
            position: absolute;
            top: 0; left: 0; bottom: 0; right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.45) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 255, 0, 0.03));
            z-index: 10;
            background-size: 100% 3px, 5px 100%;
            pointer-events: none;
        }
        .vignette {
            box-shadow: inset 0 0 160px rgba(0,0,0,0.95);
        }
        * {
            -webkit-tap-highlight-color: transparent;
            outline: none;
        }
        ::-webkit-scrollbar {
            width: 4px;
        }
        ::-webkit-scrollbar-track {
            background: #09090b;
        }
        ::-webkit-scrollbar-thumb {
            background: #27272a;
            border-radius: 2px;
        }
    </style>
</head>
<body class="w-screen h-screen flex items-center justify-center text-gray-200">

<div id="game-container" class="relative w-full h-full max-w-6xl max-h-screen bg-black md:rounded-2xl border border-zinc-800/80 shadow-2xl overflow-hidden flex flex-col md:flex-row">
    
    <!-- PAINEL DE STATUS ESQUERDO (Desktop) -->
    <div id="sidebar" class="hidden md:flex w-80 bg-zinc-950 border-r border-zinc-900 p-5 flex-col justify-between z-20">
        <div>
            <div class="border-b border-zinc-900 pb-4 mb-4">
                <div class="flex items-center gap-2 text-red-500 font-bold tracking-widest text-[10px] uppercase retro-font">
                    <span class="w-2 h-2 rounded-full bg-red-600 animate-pulse"></span>
                    OPERAÇÃO: ESCAPE CO-OP
                </div>
                <h1 class="text-xl font-black mt-1 text-zinc-100 tracking-tight">ST. JAMES <span class="text-red-600">ISLAND</span></h1>
                <div class="text-[10px] text-zinc-500 mt-1 uppercase" id="network-status">Iniciando rádio militar...</div>
                <div class="text-[11px] text-amber-500 mt-1.5 uppercase font-bold bg-amber-950/20 border border-amber-900/30 px-2 py-1 rounded hidden" id="room-indicator-box">
                    <i class="fa-solid fa-satellite-dish mr-1"></i> <span id="room-indicator">Canal Ativo</span>
                </div>
            </div>

            <!-- Diretrizes do Jogador -->
            <div class="space-y-3">
                <h3 class="text-xs font-bold text-zinc-400 uppercase tracking-wider flex items-center justify-between">
                    <span>Suas Diretrizes</span>
                    <span class="text-[10px] text-amber-500 font-mono animate-pulse" id="player-codename">AGENTE</span>
                </h3>
                <ul id="objective-list" class="space-y-2.5 text-xs retro-font">
                    <li id="obj-primary" class="flex items-start gap-2 text-zinc-400">
                        <i class="fa-regular fa-square mt-0.5 text-zinc-600"></i>
                        <span id="obj-primary-desc">Carregando missão secreta...</span>
                    </li>
                    <li id="obj-evidence" class="flex items-start gap-2 text-zinc-400">
                        <i class="fa-regular fa-square mt-0.5 text-zinc-600"></i>
                        <span>Extrair Arquivos de Prova <span class="text-amber-500 font-bold" id="evidence-count">0/3</span></span>
                    </li>
                    <li id="obj-escape" class="flex items-start gap-2 opacity-40">
                        <i class="fa-regular fa-square mt-0.5 text-zinc-700"></i>
                        <span>Escapar no Cais Sul via Iate</span>
                    </li>
                </ul>
            </div>

            <div class="mt-6 pt-4 border-t border-zinc-900">
                <h3 class="text-xs font-bold text-zinc-400 uppercase tracking-wider mb-2">Agentes no Canal (<span id="player-count">1</span>)</h3>
                <div id="players-lobby-list" class="space-y-1.5 text-xs max-h-48 overflow-y-auto pr-1"></div>
            </div>
        </div>

        <!-- Barra de Estado Física do Jogador -->
        <div class="pt-4 border-t border-zinc-900 space-y-3">
            <div class="flex justify-between items-center text-xs">
                <span class="text-zinc-500 uppercase font-bold">Estado</span>
                <span id="player-status" class="text-green-500 font-bold animate-pulse">Furtivo</span>
            </div>
            <div>
                <div class="flex justify-between text-[9px] text-zinc-500 mb-1">
                    <span>NÍVEL DE RUÍDO</span>
                    <span id="noise-text" class="text-zinc-400">SILENCIOSO</span>
                </div>
                <div class="w-full h-1 bg-zinc-900 rounded-full overflow-hidden">
                    <div id="noise-bar" class="w-0 h-full bg-blue-500 transition-all duration-100"></div>
                </div>
            </div>
            <div class="flex justify-between items-center text-xs text-zinc-400">
                <span>Distrações (Pedras):</span>
                <span id="rock-inventory" class="text-amber-500 font-bold"><i class="fa-solid fa-circle mr-1 text-[8px]"></i> 3 / 3</span>
            </div>
        </div>
    </div>

    <!-- ÁREA CENTRAL DO CANVAS E INTERFACES -->
    <div class="flex-1 relative bg-zinc-950 flex flex-col items-center justify-center overflow-hidden">
        
        <!-- Canvas Principal -->
        <canvas id="gameCanvas" class="w-full h-full block bg-zinc-950 scanlines"></canvas>
        <div class="absolute inset-0 pointer-events-none vignette"></div>

        <!-- Notificação de Sistema Customizada -->
        <div id="sys-notification" class="absolute bottom-6 left-1/2 -translate-x-1/2 bg-black/95 border border-zinc-800 px-4 py-2.5 rounded-xl text-xs text-zinc-200 retro-font pointer-events-none opacity-0 transition-opacity duration-300 z-50 flex items-center gap-2">
            <i class="fa-solid fa-circle-info text-blue-400" id="notification-icon"></i>
            <span id="notification-text">Notificação do Sistema</span>
        </div>

        <!-- HUD Superior de Alerta -->
        <div class="absolute top-3 left-3 right-3 bg-zinc-950/90 border border-zinc-900 p-2.5 rounded-lg flex items-center justify-between pointer-events-none backdrop-blur z-10">
            <div class="flex items-center gap-2">
                <i class="fa-solid fa-triangle-exclamation text-amber-500 animate-pulse text-sm" id="alarm-icon"></i>
                <div>
                    <div class="text-[8px] text-zinc-500 font-bold uppercase">ALERTA GERAL DA ILHA</div>
                    <div class="text-xs text-zinc-200 font-bold tracking-tight" id="alarm-status">PATRULHA PADRÃO</div>
                </div>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-[10px] text-zinc-400 retro-font id-indicator-mobile bg-zinc-900/50 px-2 py-0.5 rounded border border-zinc-800 text-amber-500 font-bold hidden">Lobby</span>
                <span class="text-[10px] text-zinc-400 retro-font hidden sm:inline" id="sp-objective-indicator"></span>
                <div class="w-24 sm:w-32 h-1.5 bg-zinc-900 rounded-full overflow-hidden border border-zinc-800">
                    <div id="global-alert-bar" class="w-0 h-full bg-red-600 transition-all duration-200"></div>
                </div>
            </div>
        </div>

        <!-- CONTROLES ADAPTADOS MOBILE -->
        <div id="mobile-hud" class="absolute inset-0 pointer-events-none hidden z-20 flex flex-col justify-between p-4">
            <div class="flex justify-between mt-14">
                <div class="bg-black/95 px-3 py-1.5 rounded-lg border border-zinc-800/80 text-[10px] retro-font text-amber-500">
                    Provas: <span id="mob-evidence-count">0/3</span> | <span id="mob-codename">Agente</span>
                </div>
                <div class="bg-black/95 px-3 py-1.5 rounded-lg border border-zinc-800/80 text-[10px] retro-font text-green-500" id="mob-status">
                    Furtivo
                </div>
            </div>

            <div class="flex justify-between items-end w-full pb-6 px-2">
                <div class="pointer-events-auto relative w-28 h-28 bg-zinc-950/80 border-2 border-zinc-800 rounded-full flex items-center justify-center shadow-2xl" id="joystick-boundary">
                    <div class="absolute w-12 h-12 bg-zinc-100 rounded-full shadow-lg border-2 border-zinc-400 opacity-90 cursor-pointer active:scale-90 transition-transform duration-75" id="joystick-stick" style="transform: translate(0px, 0px);"></div>
                </div>

                <div class="flex flex-col gap-4 pointer-events-auto">
                    <button id="btn-throw-stone" class="w-14 h-14 bg-amber-600/90 hover:bg-amber-600 text-white rounded-full flex flex-col items-center justify-center shadow-lg border border-amber-500/50 active:scale-90 transition-all">
                        <i class="fa-solid fa-bullseye text-lg"></i>
                        <span class="text-[7px] font-bold uppercase mt-0.5">Mirar</span>
                    </button>
                    <button id="btn-toggle-flashlight" class="w-14 h-14 bg-zinc-850/95 hover:bg-zinc-800 text-zinc-100 rounded-full flex flex-col items-center justify-center shadow-lg border border-zinc-700/50 active:scale-90 transition-all">
                        <i class="fa-solid fa-lightbulb text-lg"></i>
                        <span class="text-[7px] font-bold uppercase mt-0.5">Luz</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- TELA DE CONFIGURAÇÃO DE ENTRADA -->
        <div id="device-screen" class="absolute inset-0 bg-zinc-950 flex flex-col items-center justify-center p-6 z-40 transition-all duration-300">
            <div class="text-center space-y-6 max-w-lg">
                <div class="inline-flex items-center gap-2 px-3 py-1 bg-red-950/40 border border-red-900/30 rounded-full text-red-500 font-bold text-xs uppercase tracking-widest retro-font">
                    <i class="fa-solid fa-gamepad animate-pulse"></i> Dispositivo de Entrada
                </div>
                <h2 class="text-3xl font-black text-white uppercase tracking-tight leading-none">Selecione seu Hardware</h2>
                <p class="text-xs sm:text-sm text-zinc-400 retro-font">
                    Adaptamos as mecânicas, o joystick virtual e a aceleração de jogo de acordo com o seu dispositivo.
                </p>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4">
                    <button id="choose-pc" class="p-5 sm:p-6 bg-zinc-900 hover:bg-zinc-850 border-2 border-zinc-800 hover:border-red-600/50 rounded-xl text-left transition-all flex flex-col justify-between gap-4">
                        <div class="w-10 h-10 bg-red-950/50 border border-red-500/30 rounded-lg flex items-center justify-center text-red-500 text-lg">
                            <i class="fa-solid fa-desktop"></i>
                        </div>
                        <div>
                            <h4 class="font-bold text-zinc-100 text-sm sm:text-base">Computador (PC)</h4>
                            <p class="text-[11px] text-zinc-500 mt-1">Movimento em WASD ou Setas. Use o clique do mouse para mirar e arremessar pedras de distração.</p>
                        </div>
                    </button>

                    <button id="choose-mobile" class="p-5 sm:p-6 bg-zinc-900 hover:bg-zinc-850 border-2 border-zinc-800 hover:border-blue-600/50 rounded-xl text-left transition-all flex flex-col justify-between gap-4">
                        <div class="w-10 h-10 bg-blue-950/50 border border-blue-500/30 rounded-lg flex items-center justify-center text-blue-400 text-lg">
                            <i class="fa-solid fa-mobile-screen-button"></i>
                        </div>
                        <div>
                            <h4 class="font-bold text-zinc-100 text-sm sm:text-base">Celular / Tablet</h4>
                            <p class="text-[11px] text-zinc-500 mt-1">Habilita o joystick analógico dinâmico (esquerdo) e botões de ação ergonômicos (direito).</p>
                        </div>
                    </button>
                </div>
            </div>
        </div>

        <!-- TELA DE SAGUÃO DE SALAS (ROOM LOBBY) -->
        <div id="room-screen" class="absolute inset-0 bg-zinc-950 flex flex-col items-center justify-center p-6 z-30 hidden transition-all duration-300 overflow-y-auto">
            <div class="w-full max-w-2xl space-y-5 my-auto">
                <div class="text-center space-y-2">
                    <div class="inline-flex items-center gap-2 px-3 py-1 bg-red-950/40 border border-red-900/30 rounded-full text-red-500 font-bold text-[11px] uppercase tracking-widest retro-font">
                        <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span> CONEXÃO DE REDE CO-OP
                    </div>
                    <h2 class="text-2xl md:text-3xl font-black text-white uppercase tracking-tight">Saguão de Operações</h2>
                    <p class="text-xs text-zinc-400 retro-font">Configure sua identidade e selecione um canal de infiltração compartilhado.</p>
                </div>

                <!-- Configurar Identidade -->
                <div class="bg-zinc-900/50 border border-zinc-850 p-4 rounded-xl space-y-3 shadow-lg">
                    <h3 class="text-xs font-bold text-zinc-400 uppercase tracking-wider flex items-center gap-1.5">
                        <i class="fa-solid fa-user-secret text-red-500"></i> Identidade do Agente
                    </h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <div>
                            <label class="block text-[10px] text-zinc-500 uppercase font-bold mb-1">Codinome</label>
                            <input id="input-codename" type="text" maxlength="14" class="w-full bg-zinc-950 border border-zinc-800 focus:border-red-600 rounded px-3 py-2 text-xs font-mono text-zinc-100 outline-none">
                        </div>
                        <div>
                            <label class="block text-[10px] text-zinc-500 uppercase font-bold mb-1">Cor de Radar</label>
                            <div class="flex gap-2.5 items-center h-9">
                                <button class="color-dot w-6 h-6 rounded-full border-2 border-transparent transition-all" data-color="#3b82f6" style="background-color: #3b82f6;"></button>
                                <button class="color-dot w-6 h-6 rounded-full border-2 border-transparent transition-all" data-color="#ef4444" style="background-color: #ef4444;"></button>
                                <button class="color-dot w-6 h-6 rounded-full border-2 border-transparent transition-all" data-color="#10b981" style="background-color: #10b981;"></button>
                                <button class="color-dot w-6 h-6 rounded-full border-2 border-transparent transition-all" data-color="#a855f7" style="background-color: #a855f7;"></button>
                                <button class="color-dot w-6 h-6 rounded-full border-2 border-transparent transition-all" data-color="#f59e0b" style="background-color: #f59e0b;"></button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Lista de Salas / Sincronizar -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <!-- Canais Públicos -->
                    <div class="bg-zinc-900/50 border border-zinc-850 p-4 rounded-xl flex flex-col justify-between space-y-3 shadow-lg">
                        <h3 class="text-xs font-bold text-zinc-400 uppercase tracking-wider flex items-center gap-1.5">
                            <i class="fa-solid fa-tower-broadcast text-zinc-500"></i> Canais de Rádio Públicos
                        </h3>
                        <div id="rooms-list-container" class="space-y-1.5 max-h-40 overflow-y-auto pr-1">
                            <div class="text-center text-[10px] text-zinc-500 py-3 retro-font">Buscando transmissões...</div>
                        </div>
                    </div>

                    <!-- Código Privado com Gerador de Token -->
                    <div class="bg-zinc-900/50 border border-zinc-850 p-4 rounded-xl flex flex-col justify-between space-y-3 shadow-lg">
                        <div class="space-y-2.5">
                            <h3 class="text-xs font-bold text-zinc-300 uppercase tracking-wider flex items-center gap-1.5">
                                <i class="fa-solid fa-lock text-red-500"></i> Operações Secretas (Privadas)
                            </h3>
                            
                            <!-- Botão Gerador de Código -->
                            <button id="btn-generate-code" class="w-full py-2 bg-zinc-800 hover:bg-zinc-750 text-zinc-100 font-bold rounded text-[10px] uppercase tracking-wider transition-all border border-zinc-750 flex items-center justify-center gap-1.5">
                                <i class="fa-solid fa-key text-amber-500"></i> Gerar Novo Código de Infiltração
                            </button>

                            <!-- Painel de exibição de código gerado -->
                            <div id="generated-code-box" class="hidden p-2.5 bg-black/60 border border-amber-950/50 rounded flex items-center justify-between">
                                <div class="text-[10px] font-bold text-amber-500 font-mono tracking-wider">
                                    CÓDIGO: <span id="lbl-generated-code" class="text-zinc-100 bg-zinc-900 px-1.5 py-0.5 rounded border border-zinc-800">NENHUM</span>
                                </div>
                                <button id="btn-copy-code" class="px-2 py-1 bg-amber-600 hover:bg-amber-500 text-white font-bold rounded text-[9px] uppercase tracking-wider transition-all flex items-center gap-1">
                                    <i class="fa-solid fa-copy"></i> Copiar
                                </button>
                            </div>

                            <div class="pt-1.5">
                                <label class="block text-[9px] text-zinc-500 uppercase font-bold mb-1">Entrar com Código Secreto</label>
                                <input id="input-custom-room" type="text" placeholder="Cole ou digite o código aqui" maxlength="25" class="w-full bg-zinc-950 border border-zinc-800 focus:border-red-600 rounded px-3 py-2 text-xs font-mono text-zinc-100 outline-none uppercase placeholder-zinc-800">
                            </div>
                        </div>

                        <button id="btn-create-room" class="w-full py-2.5 bg-red-600 hover:bg-red-700 text-white font-bold rounded text-xs uppercase tracking-wider transition-all shadow-md">
                            <i class="fa-solid fa-plug mr-1"></i> Conectar Código
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- TELA INICIAL / INTRO -->
        <div id="start-screen" class="absolute inset-0 bg-zinc-950 flex flex-col items-center justify-center p-6 z-30 hidden transition-all duration-500">
            <div class="max-w-xl text-center z-10 space-y-5">
                <div class="inline-flex items-center gap-2 px-3 py-1 bg-red-950/50 border border-red-900/40 rounded-full text-red-500 font-bold text-xs uppercase tracking-widest retro-font">
                    <i class="fa-solid fa-eye-slash animate-pulse"></i> Infiltração Silenciosa
                </div>
                <h2 class="text-3xl md:text-5xl font-black tracking-tight text-white leading-none">
                    FUGA DE <br><span class="text-red-600">LITTLE ST. JAMES</span>
                </h2>
                <p class="text-xs md:text-sm text-zinc-400 leading-relaxed retro-font">
                    Infiltre-se sob o véu de uma severa tempestade tropical. Hackeie os servidores e recolha evidências criptografadas essenciais para expor o esquema global. Desvie dos agentes e câmeras térmicas.
                </p>

                <div class="p-4 bg-zinc-900/60 border border-zinc-800/80 rounded-xl text-left space-y-2">
                    <h4 class="text-xs font-bold text-zinc-300 uppercase tracking-widest flex items-center gap-1.5">
                        <i class="fa-solid fa-circle-nodes text-red-500"></i> Cooperação Real Multijogador:
                    </h4>
                    <p class="text-[11px] text-zinc-400 leading-normal">
                        • <b>Mesmo Canal Ativo:</b> Todos os agentes na mesma sala jogam juntos simultaneamente no mesmo mapa!<br>
                        • <b>Lanternas Táticas:</b> A iluminação de outros jogadores ajuda a clarear as áreas escuras para todos.<br>
                        • <b>Cuidado com Ruídos:</b> Arremesse pedras para desviar patrulhas e ajudar seus aliados em perigo.
                    </p>
                </div>

                <div class="flex flex-col sm:flex-row gap-3 justify-center">
                    <button id="start-btn" class="px-8 py-3.5 bg-red-600 hover:bg-red-700 text-white font-bold rounded-lg shadow-lg active:scale-95 transition-all text-xs uppercase tracking-wider">
                        <i class="fa-solid fa-play mr-1.5"></i> Iniciar Missão
                    </button>
                    <button id="audio-toggle-btn" class="px-6 py-3.5 bg-zinc-900 hover:bg-zinc-800 text-zinc-300 font-bold rounded-lg border border-zinc-800 transition-all text-xs flex items-center justify-center gap-2">
                        <i class="fa-solid fa-volume-high text-amber-500" id="audio-icon-btn"></i> Áudio Ativo
                    </button>
                </div>
            </div>
        </div>

        <!-- TELA DE GAME OVER -->
        <div id="gameover-screen" class="absolute inset-0 bg-zinc-950/95 flex flex-col items-center justify-center p-6 z-30 hidden transition-all duration-300">
            <div class="text-center space-y-5 max-w-md">
                <div class="w-16 h-16 bg-red-950/50 border border-red-500/30 rounded-full flex items-center justify-center mx-auto text-red-500 text-2xl animate-bounce">
                    <i class="fa-solid fa-skull"></i>
                </div>
                <h2 class="text-2xl font-black text-white uppercase tracking-tight">Agente Neutralizado</h2>
                <p class="text-xs text-zinc-400 retro-font">
                    Você foi detectado e preso pelas forças táticas privadas da ilha.
                </p>
                <div class="p-4 bg-zinc-900/50 border border-zinc-850 rounded-lg text-left text-xs space-y-1 text-zinc-500">
                    <div>Motivo: <span class="text-red-400 font-semibold" id="fail-reason">Falta de cobertura física</span></div>
                    <div>Provas coletadas: <span class="text-amber-500 font-bold" id="fail-evidence">0 / 3</span></div>
                </div>
                <button id="restart-btn" class="px-8 py-3 bg-zinc-100 hover:bg-white text-zinc-950 font-bold rounded-lg transition-all text-xs uppercase tracking-wider w-full">
                    <i class="fa-solid fa-rotate-left mr-1.5"></i> Nova Infiltração
                </button>
            </div>
        </div>

        <!-- TELA DE VITÓRIA -->
        <div id="victory-screen" class="absolute inset-0 bg-zinc-950/95 flex flex-col items-center justify-center p-6 z-30 hidden transition-all duration-300">
            <div class="text-center space-y-5 max-w-md">
                <div class="w-16 h-16 bg-green-950/50 border border-green-500/30 rounded-full flex items-center justify-center mx-auto text-green-400 text-3xl animate-pulse">
                    <i class="fa-solid fa-ship"></i>
                </div>
                <h2 class="text-2xl md:text-3xl font-black text-green-500 uppercase tracking-tight">Fuga Bem-Sucedida</h2>
                <p class="text-xs text-zinc-300 leading-relaxed retro-font">
                    Você alcançou o cais de escape com todos os dados protegidos.
                </p>
                <div class="p-5 bg-zinc-900/50 border border-zinc-800 rounded-xl space-y-2 text-left text-xs">
