// Inicializa a conexão com o broker MQTT global gratuito (EMQX com fallback para HiveMQ)
function setupMultiplayer() {
    const netStatus = document.getElementById('network-status');
    const inputName = document.getElementById('input-codename');
    
    if (inputName) {
        inputName.value = myCodename;
    }

    netStatus.textContent = "SINTONIZANDO RÁDIO...";
    
    try {
        // Tentativa de conexão ao Broker MQTT robusto via WSS
        mqttClient = mqtt.connect('wss://broker.emqx.io:8084/mqtt', {
            clientId: 'stjames_' + myUid,
            clean: true,
            connectTimeout: 5000,
            reconnectPeriod: 2000
        });

        mqttClient.on('connect', () => {
            isOnline = true;
            netStatus.textContent = "CONEXÃO ATIVA - SELECIONE CANAL";
            netStatus.className = "text-[10px] text-green-500 mt-1 uppercase animate-pulse font-bold";
            
            // Ativa visualização da tela de escolha de canais
            document.getElementById('room-screen').classList.remove('hidden');

            // Inscreve-se na lista global de descoberta de salas
            mqttClient.subscribe('stjames/coop/rooms/registry/+', (err) => {
                if (err) console.error("Falha ao escutar registro de salas:", err);
            });
        });

        mqttClient.on('message', (topic, message) => {
            try {
                const payload = JSON.parse(message.toString());
                
                // Trata as mensagens de descoberta de salas ativas
                if (topic.startsWith('stjames/coop/rooms/registry/')) {
                    const roomId = topic.replace('stjames/coop/rooms/registry/', '');
                    roomListRegistry[roomId] = {
                        id: roomId,
                        activePlayers: payload.count || 1,
                        timestamp: Date.now()
                    };
                    renderRoomsList();
                }

                // Trata o tráfego em tempo real dentro da sala ativa
                if (activeRoomId && topic.startsWith(`stjames/coop/rooms/active/${activeRoomId}/`)) {
                    const senderId = topic.split('/').pop();
                    if (senderId !== myUid) {
                        if (payload.type === 'state') {
                            playersInLobby[senderId] = {
                                uid: senderId,
                                name: payload.name,
                                color: payload.color,
                                x: payload.x,
                                y: payload.y,
                                angle: payload.angle,
                                flashlightOn: payload.flashlightOn,
                                status: payload.status,
                                alertLevel: payload.alertLevel,
                                lastUpdate: Date.now()
                            };
                            updatePlayersLobbyList();
                        } else if (payload.type === 'stone') {
                            flyingStones.push(new FlyingStone(payload.sx, payload.sy, payload.tx, payload.ty));
                        } else if (payload.type === 'collect') {
                            const item = items.find(i => i.id === payload.itemId);
                            if (item && !item.collected) {
                                item.collected = true;
                                sound.playCollect();
                                createAlertParticle(item.x, item.y, `PARCEIRO CO-OP EXTRAIU: ${item.name}`);
                                if (item.type === 'primary') {
                                    player.primaryObjectiveCompleted = true;
                                }
                                updateObjectivesUI();
                            }
                        }
                    }
                }
            } catch(e) {
                console.warn("Erro ao ler pacote de rádio:", e);
            }
        });

        mqttClient.on('error', (err) => {
            console.warn("Erro no Broker MQTT primário, tentando HiveMQ:", err);
            // Fallback imediato para broker alternativo
            try {
                mqttClient = mqtt.connect('wss://broker.hivemq.com:8884/mqtt', {
                    clientId: 'stjames_fb_' + myUid,
                    clean: true
                });
            } catch(e) {
                runSimulatedMultiplayer();
            }
        });

    } catch (e) {
        console.warn("Sem conexão com rádio real-time, rodando em simulação local:", e);
        runSimulatedMultiplayer();
    }
}

function renderRoomsList() {
    const container = document.getElementById('rooms-list-container');
    if (!container) return;

    container.innerHTML = "";

    const defaultRooms = ["ALPHA", "BRAVO", "CHARLIE"];
    
    // Filtra salas inativas por tempo de expiração
    const now = Date.now();
    Object.keys(roomListRegistry).forEach(key => {
        if (now - roomListRegistry[key].timestamp > 10000) {
            delete roomListRegistry[key];
        }
    });

    defaultRooms.forEach(roomId => {
        const roomData = roomListRegistry[roomId];
        const playerCnt = roomData ? roomData.activePlayers : 0;
        
        container.innerHTML += `
            <button onclick="window.joinCoopRoom('${roomId}')" class="w-full p-2.5 bg-zinc-900/85 hover:bg-red-950/40 border border-zinc-800 hover:border-red-600 text-left rounded-lg flex items-center justify-between text-xs transition-all active:scale-95">
                <span class="font-mono text-zinc-100 font-bold"><i class="fa-solid fa-tower-broadcast mr-1.5 text-zinc-500"></i> CANAL_${roomId}</span>
                <span class="text-[9px] text-zinc-400 font-mono">AGENTES: <span class="text-amber-500 font-bold">${playerCnt}</span></span>
            </button>
        `;
    });

    // Exibe outras salas criadas de forma dinâmica
    Object.keys(roomListRegistry).forEach(roomId => {
        if (!defaultRooms.includes(roomId)) {
            const roomData = roomListRegistry[roomId];
            container.innerHTML += `
                <button onclick="window.joinCoopRoom('${roomId}')" class="w-full p-2.5 bg-zinc-900/85 hover:bg-red-950/40 border border-zinc-850 hover:border-amber-600 text-left rounded-lg flex items-center justify-between text-xs transition-all active:scale-95">
