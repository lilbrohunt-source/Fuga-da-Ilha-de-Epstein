function updateGame() {
    if (gameState === 'CUTSCENE') {
        updateCutscene();
        return;
    }
    if (gameState !== 'PLAYING') return;

    if (screenShake.duration > 0) {
        screenShake.x = (Math.random() - 0.5) * screenShake.intensity;
        screenShake.y = (Math.random() - 0.5) * screenShake.intensity;
        screenShake.duration--;
    } else {
        screenShake.x = 0;
        screenShake.y = 0;
    }

    lightningTimer--;
    if (lightningTimer <= 0) {
        lightningActive = true;
        sound.playThunder();
        triggerScreenShake(24, 7);
        lightningTimer = 300 + Math.random() * 400;
    } else if (lightningActive && Math.random() < 0.12) {
        lightningActive = false;
    }

    let ax = 0; let ay = 0;

    if (inputDevice === 'PC') {
        if (keys['w'] || keys['arrowup']) ay = -1;
        if (keys['s'] || keys['arrowdown']) ay = 1;
        if (keys['a'] || keys['arrowleft']) ax = -1;
        if (keys['d'] || keys['arrowright']) ax = 1;

        if (ax !== 0 && ay !== 0) {
            let len = Math.sqrt(ax*ax + ay*ay);
            ax /= len; ay /= len;
        }
    } else {
        ax = joystick.vx;
        ay = joystick.vy;
    }

    player.vx += ax * 0.6;
    player.vy += ay * 0.6;

    player.vx *= player.friction;
    player.vy *= player.friction;

    let isMoving = Math.abs(player.vx) > 0.05 || Math.abs(player.vy) > 0.05;
    if (isMoving) {
        moveAndResolve(player, player.vx, player.vy);
        player.angle = Math.atan2(player.vy, player.vx);
        player.noiseLevel = player.flashlightOn ? 75 : 30;

        if (Math.random() < 0.12 && !player.inBush) {
            footstepRipples.push({
                x: player.x,
                y: player.y,
                r: 1.5,
                maxR: player.flashlightOn ? 70 : 35,
                alpha: 1.0
            });
        }
    } else {
        player.noiseLevel = 0;
    }

    player.x = Math.max(player.radius + 15, Math.min(WORLD_WIDTH - player.radius - 15, player.x));
    player.y = Math.max(player.radius + 15, Math.min(WORLD_HEIGHT - player.radius - 15, player.y));

    player.inBush = false;
    bushes.forEach(bush => {
        let dx = player.x - bush.x; let dy = player.y - bush.y;
        if (Math.sqrt(dx*dx + dy*dy) < bush.r) {
            player.inBush = true;
        }
    });

    const statusText = player.inBush && !player.flashlightOn ? "Oculto" : (player.flashlightOn ? "Lanternas ON" : "Furtivo");
    document.getElementById('player-status').textContent = statusText;
    const mobStatus = document.getElementById('mob-status');
    if (mobStatus) mobStatus.textContent = statusText;

    // Sincronizando dados de rede MQTT
    syncPlayerPosition();

    searchlights.forEach(sl => sl.update());
    securityCameras.forEach(cam => cam.update());

    let anyChasing = false;
    guards.forEach(g => {
        g.update();
        if (g.state === 'CHASING') anyChasing = true;

        let dx = player.x - g.x; let dy = player.y - g.y;
        if (Math.sqrt(dx*dx + dy*dy) < player.radius + g.radius) {
            triggerGameOver("Interceptado por guardas de patrulha externa");
        }
    });

    // Multiplayer Cooperativo: Calcula nível de alerta consolidado do time ativo na sala
    let highestPeerAlert = 0;
    Object.values(playersInLobby).forEach(p => {
        if (p.alertLevel > highestPeerAlert) {
            highestPeerAlert = p.alertLevel;
        }
    });

    if (anyChasing) {
        globalAlertLevel = Math.min(100, globalAlertLevel + 0.35);
    } else {
        globalAlertLevel = Math.max(0, globalAlertLevel - 0.15);
    }

    let absoluteAlertLevel = Math.max(globalAlertLevel, highestPeerAlert);
    highestAlert = Math.max(highestAlert, Math.round(absoluteAlertLevel));

    const alertBar = document.getElementById('global-alert-bar');
    const alertStatus = document.getElementById('alarm-status');
    alertBar.style.width = absoluteAlertLevel + '%';
    if (absoluteAlertLevel > 50) {
        alertStatus.textContent = "ALERTA DA COSTA EM ALTA";
        alertStatus.className = "text-xs text-red-500 font-extrabold animate-pulse";
    } else {
        alertStatus.textContent = "PATRULHA PADRÃO";
        alertStatus.className = "text-xs text-zinc-300 font-bold";
    }

    for (let i = flyingStones.length - 1; i >= 0; i--) {
        let s = flyingStones[i];
        if (s.update()) {
            sound.playStoneDrop();
            distractions.push({
                x: s.targetX, y: s.targetY, radius: 1, maxRadius: 180, timer: 0
            });

            guards.forEach(g => {
                let gdx = g.x - s.targetX;
                let gdy = g.y - s.targetY;
                let gdist = Math.sqrt(gdx*gdx + gdy*gdy);
                if (gdist < 180 && g.state !== 'CHASING') {
                    g.state = 'INVESTIGATING';
                    g.targetX = s.targetX + (Math.random() - 0.5) * 12;
                    g.targetY = s.targetY + (Math.random() - 0.5) * 12;
                    g.investigateTimer = 140;
                    g.speed = g.baseSpeed * 1.2;
                    createAlertParticle(g.x, g.y, "RUÍDO SUSPEITO");
                }
            });
            flyingStones.splice(i, 1);
        }
    }

    // Coleta cooperativa: sincroniza item pego com todos da mesma sala
    items.forEach(item => {
        if (item.collected) return;
        let dx = player.x - item.x; let dy = player.y - item.y;
        if (Math.sqrt(dx*dx + dy*dy) < player.radius + 15) {
            item.collected = true;
            sound.playCollect();
            createAlertParticle(item.x, item.y, `+1 ${item.name}`);

            if (item.type === 'primary') {
                player.primaryObjectiveCompleted = true;
                createAlertParticle(item.x, item.y, "ARQUIVOS HACKEADOS");
            }
            updateObjectivesUI();
            
            // Publica a coleta no canal real-time
            publishCollectAction(item.id);
        }
    });

    createRain();
    
    particles.forEach(p => p.update());
    particles = particles.filter(p => p.life > 0);

    footstepRipples.forEach(r => {
        r.r += 1.4;
        r.alpha -= 0.03;
    });
    footstepRipples = footstepRipples.filter(r => r.alpha > 0);

    distractions.forEach(d => { d.radius += 4.0; d.timer++; });
    distractions = distractions.filter(d => d.radius < d.maxRadius);

    camera.width = canvas.width;
    camera.height = canvas.height;
    camera.x = player.x - camera.width / 2;
    camera.y = player.y - camera.height / 2;
    camera.x = Math.max(0, Math.min(WORLD_WIDTH - camera.width, camera.x));
    camera.y = Math.max(0, Math.min(WORLD_HEIGHT - camera.height, camera.y));
}

function drawGame() {
    if (canvas.width <= 0 || canvas.height <= 0 || !offscreenCanvas || offscreenCanvas.width <= 0 || offscreenCanvas.height <= 0) {
        return;
    }

    ctx.fillStyle = '#010102';
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    ctx.save();
    ctx.translate(-camera.x + screenShake.x, -camera.y + screenShake.y);

    ctx.fillStyle = patternGrass;
    ctx.fillRect(45, 45, WORLD_WIDTH - 90, WORLD_HEIGHT - 90);

    ctx.fillStyle = patternLab;
    ctx.fillRect(250, 500, 400, 385);

    ctx.fillStyle = patternTemple;
    ctx.fillRect(1800, 800, 300, 335);

    ctx.fillStyle = patternMansion;
    ctx.fillRect(900, 300, 600, 435);

    ctx.fillStyle = '#1c1917';
    ctx.fillRect(WORLD_WIDTH - 250, WORLD_HEIGHT - 220, 205, 175);

    ctx.strokeStyle = 'rgba(255, 255, 255, 0.006)';
    ctx.lineWidth = 1;
    for (let x = 0; x < WORLD_WIDTH; x += 150) {
        ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, WORLD_HEIGHT); ctx.stroke();
    }
    for (let y = 0; y < WORLD_HEIGHT; y += 150) {
        ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(WORLD_WIDTH, y); ctx.stroke();
    }

    bushes.forEach(b => b.draw());
    items.forEach(item => item.draw());
    walls.forEach(w => w.draw());

    // Desenha parceiros de equipe cooperativa em tempo real
    const now = Date.now();
    Object.values(playersInLobby).forEach(p => {
        if (now - p.lastUpdate < 6000) {
            ctx.save();
            ctx.translate(p.x, p.y);
            ctx.rotate(p.angle || 0);

            ctx.fillStyle = p.color;
            ctx.beginPath(); ctx.arc(0, 0, 14, 0, Math.PI*2); ctx.fill();

            ctx.fillStyle = '#060608';
            ctx.beginPath(); ctx.arc(0, 0, 8, 0, Math.PI*2); ctx.fill();

            ctx.fillStyle = p.color;
            ctx.fillRect(5, -2, 3, 4);
            ctx.restore();

            ctx.save();
            ctx.fillStyle = p.color;
            ctx.font = 'bold 9px Courier Prime';
            ctx.textAlign = 'center';
            ctx.fillText(p.name, p.x, p.y - 20);
            ctx.restore();
        }
    });

    guards.forEach(g => g.draw());
    searchlights.forEach(sl => sl.draw());
    securityCameras.forEach(cam => cam.draw());

    if (aimingMode) {
        ctx.strokeStyle = 'rgba(245, 158, 11, 0.4)';
        ctx.lineWidth = 1.5;
        ctx.setLineDash([5, 5]);
        ctx.beginPath();
        ctx.moveTo(player.x, player.y);
        ctx.lineTo(aimTargetX, aimTargetY);
        ctx.stroke();
        ctx.setLineDash([]); 

        ctx.fillStyle = 'rgba(245, 158, 11, 0.2)';
        ctx.beginPath();
        ctx.arc(aimTargetX, aimTargetY, 8, 0, Math.PI*2);
        ctx.fill();
        ctx.strokeStyle = '#f59e0b';
        ctx.stroke();
    }

    flyingStones.forEach(s => s.draw());

    ctx.save();
    ctx.translate(player.x, player.y);
    ctx.rotate(player.angle);

    ctx.fillStyle = myColor;
    ctx.beginPath(); ctx.arc(0, 0, player.radius, 0, Math.PI*2); ctx.fill();

    ctx.fillStyle = '#020203';
    ctx.beginPath(); ctx.arc(0, 0, 7, 0, Math.PI*2); ctx.fill();

    ctx.fillStyle = player.inBush ? '#10b981' : '#f59e0b';
    ctx.fillRect(4, -3, 3, 6);
    ctx.restore();

    ctx.save();
    ctx.fillStyle = myColor;
    ctx.font = 'bold 9px Courier Prime';
    ctx.textAlign = 'center';
    ctx.fillText(myCodename, player.x, player.y - 21);
    ctx.restore();

    distractions.forEach(d => {
        ctx.strokeStyle = `rgba(245, 158, 11, ${1 - d.radius / d.maxRadius})`;
        ctx.lineWidth = 1.5;
        ctx.beginPath();
        ctx.arc(d.x, d.y, d.radius, 0, Math.PI*2);
        ctx.stroke();
    });

    footstepRipples.forEach(r => {
        ctx.strokeStyle = `rgba(59, 130, 246, ${r.alpha})`;
        ctx.lineWidth = 1.2;
        ctx.beginPath();
        ctx.arc(r.x, r.y, r.r, 0, Math.PI*2);
        ctx.stroke();
    });

    ctx.restore(); 

    if (!lightningActive) {
        offscreenCtx.fillStyle = 'rgba(2, 2, 4, 0.85)';
        offscreenCtx.fillRect(0, 0, canvas.width, canvas.height);

        offscreenCtx.globalCompositeOperation = 'destination-out';

        // Lanterna do jogador local
        if (player.flashlightOn) {
            let relPX = player.x - camera.x;
            let relPY = player.y - camera.y;
            let flashDist = 230;
            let flashAngle = Math.PI / 4.2;

            let grad = offscreenCtx.createRadialGradient(relPX, relPY, 4, relPX, relPY, flashDist);
            grad.addColorStop(0, 'rgba(255, 255, 255, 1.0)');
            grad.addColorStop(0.4, 'rgba(255, 255, 255, 0.4)');
            grad.addColorStop(1, 'rgba(255, 255, 255, 0)');

            offscreenCtx.fillStyle = grad;
            offscreenCtx.beginPath();
            offscreenCtx.moveTo(relPX, relPY);
            offscreenCtx.arc(relPX, relPY, flashDist, player.angle - flashAngle, player.angle + flashAngle);
            offscreenCtx.closePath();
            offscreenCtx.fill();
        }

        // CO-OP: Lanternas dos parceiros acesas em tempo real iluminam seu mapa!
        Object.values(playersInLobby).forEach(p => {
            if (p.flashlightOn && (now - p.lastUpdate < 6000)) {
                let relPX = p.x - camera.x;
                let relPY = p.y - camera.y;
                let flashDist = 230;
                let flashAngle = Math.PI / 4.2;

                let grad = offscreenCtx.createRadialGradient(relPX, relPY, 4, relPX, relPY, flashDist);
                grad.addColorStop(0, 'rgba(255, 255, 255, 1.0)');
                grad.addColorStop(0.4, 'rgba(255, 255, 255, 0.4)');
                grad.addColorStop(1, 'rgba(255, 255, 255, 0)');

                offscreenCtx.fillStyle = grad;
                offscreenCtx.beginPath();
                offscreenCtx.moveTo(relPX, relPY);
                offscreenCtx.arc(relPX, relPY, flashDist, (p.angle || 0) - flashAngle, (p.angle || 0) + flashAngle);
                offscreenCtx.closePath();
                offscreenCtx.fill();
            }
        });

        // Cones de visão dos guardas
        guards.forEach(g => {
            let relX = g.x - camera.x;
            let relY = g.y - camera.y;
            if (relX < -150 || relX > canvas.width + 150 || relY < -150 || relY > canvas.height + 150) return;

            let grad = offscreenCtx.createRadialGradient(relX, relY, 8, relX, relY, g.viewDistance);
            grad.addColorStop(0, 'rgba(255, 255, 255, 0.85)');
            grad.addColorStop(1, 'rgba(255, 255, 255, 0)');

            offscreenCtx.fillStyle = grad;
            offscreenCtx.beginPath();
            offscreenCtx.moveTo(relX, relY);
            offscreenCtx.arc(relX, relY, g.viewDistance, g.angle - g.viewAngle, g.angle + g.viewAngle);
            offscreenCtx.closePath();
            offscreenCtx.fill();
        });

        securityCameras.forEach(cam => {
            let relX = cam.x - camera.x;
            let relY = cam.y - camera.y;
            let grad = offscreenCtx.createRadialGradient(relX, relY, 8, relX, relY, cam.viewDistance);
            grad.addColorStop(0, 'rgba(255, 255, 255, 0.75)');
            grad.addColorStop(1, 'rgba(255, 255, 255, 0)');

            offscreenCtx.fillStyle = grad;
            offscreenCtx.beginPath();
            offscreenCtx.moveTo(relX, relY);
            offscreenCtx.arc(relX, relY, cam.viewDistance, cam.angle - cam.viewAngle, cam.angle + cam.viewAngle);
            offscreenCtx.closePath();
            offscreenCtx.fill();
        });

        searchlights.forEach(sl => {
            let relX = sl.focalX - camera.x;
            let relY = sl.focalY - camera.y;
            let grad = offscreenCtx.createRadialGradient(relX, relY, 8, relX, relY, sl.radius);
            grad.addColorStop(0, 'rgba(255, 255, 255, 0.85)');
            grad.addColorStop(1, 'rgba(255, 255, 255, 0)');

            offscreenCtx.fillStyle = grad;
            offscreenCtx.beginPath();
            offscreenCtx.arc(relX, relY, sl.radius, 0, Math.PI*2);
            offscreenCtx.fill();
        });

        offscreenCtx.globalCompositeOperation = 'source-over';
        ctx.drawImage(offscreenCanvas, 0, 0);
    } else {
        ctx.fillStyle = 'rgba(219, 234, 254, 0.2)';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
    }

    ctx.save();
    ctx.translate(-camera.x, -camera.y);

    guards.forEach(g => {
        let grad = ctx.createRadialGradient(g.x, g.y, 8, g.x, g.y, g.viewDistance);
        if (g.state === 'CHASING') {
            grad.addColorStop(0, 'rgba(239, 68, 68, 0.22)');
            grad.addColorStop(1, 'rgba(0, 0, 0, 0)');
        } else {
            grad.addColorStop(0, 'rgba(251, 146, 60, 0.1)');
            grad.addColorStop(1, 'rgba(0, 0, 0, 0)');
        }
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.moveTo(g.x, g.y);
        ctx.arc(g.x, g.y, g.viewDistance, g.angle - g.viewAngle, g.angle + g.viewAngle);
        ctx.closePath();
        ctx.fill();
    });

    searchlights.forEach(sl => {
        let grad = ctx.createRadialGradient(sl.focalX, sl.focalY, 4, sl.focalX, sl.focalY, sl.radius);
        grad.addColorStop(0, 'rgba(253, 224, 71, 0.15)');
        grad.addColorStop(1, 'rgba(0, 0, 0, 0)');
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.arc(sl.focalX, sl.focalY, sl.radius, 0, Math.PI*2);
        ctx.fill();
    });

    particles.forEach(p => p.draw());

    ctx.restore();
}

function triggerCutscene() {
    gameState = 'CUTSCENE';
    cutsceneFrame = 0;
    cutsceneTimeline = 0;
    cutsceneYachtX = 100;
    cutsceneYachtY = canvas.height / 2 + 30;
    sound.stopAmbience();
    sound.playThunder();
}

function updateCutscene() {
    cutsceneFrame++;
    cutsceneYachtX += 1.6; 
    cutsceneYachtY += Math.sin(cutsceneFrame * 0.04) * 0.3; 

    if (cutsceneFrame % 250 === 0) {
        cutsceneTimeline++;
        sound.playThunder();
    }

    if (cutsceneTimeline > 4) {
        triggerVictory();
    }
}

function drawCutscene() {
    if (canvas.width <= 0 || canvas.height <= 0) {
        return;
    }

    ctx.fillStyle = '#010103';
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    for (let i = 0; i < 5; i++) {
        let rx = Math.random() * canvas.width;
        let ry = Math.random() * canvas.height;
        ctx.strokeStyle = 'rgba(148, 163, 184, 0.18)';
        ctx.lineWidth = 1.2;
        ctx.beginPath();
        ctx.moveTo(rx, ry);
        ctx.lineTo(rx - 12, ry + 25);
        ctx.stroke();
    }

    ctx.save();
    ctx.translate(cutsceneYachtX, cutsceneYachtY);
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(-22, -10, 50, 16);
    ctx.beginPath();
    ctx.moveTo(28, -10);
    ctx.lineTo(40, 6);
    ctx.lineTo(28, 6);
    ctx.closePath();
    ctx.fill();
    
    ctx.fillStyle = '#1e293b';
    ctx.fillRect(-8, -22, 26, 12);
    ctx.fillStyle = 'rgba(59, 130, 246, 0.5)';
    ctx.fillRect(-4, -18, 7, 7);
    ctx.restore();

    let fGrad = ctx.createLinearGradient(cutsceneYachtX + 35, cutsceneYachtY, cutsceneYachtX + 280, cutsceneYachtY + 45);
    fGrad.addColorStop(0, 'rgba(255, 255, 255, 0.32)');
    fGrad.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = fGrad;
    ctx.beginPath();
    ctx.moveTo(cutsceneYachtX + 35, cutsceneYachtY - 4);
    ctx.lineTo(cutsceneYachtX + 290, cutsceneYachtY - 50);
    ctx.lineTo(cutsceneYachtX + 290, cutsceneYachtY + 80);
    ctx.closePath();
    ctx.fill();

    ctx.fillStyle = 'rgba(0, 0, 0, 0.8)';
    ctx.fillRect(0, canvas.height - 120, canvas.width, 120);
    ctx.strokeStyle = '#27272a';
    ctx.lineWidth = 1.5;
    ctx.strokeRect(0, canvas.height - 120, canvas.width, 120);

    ctx.fillStyle = '#f3f4f6';
    ctx.font = 'bold 15px Courier Prime';
    ctx.textAlign = 'center';

    let narrativeText = "";
    if (cutsceneTimeline === 0) {
        narrativeText = "O Iate cruza a fronteira das águas territoriais de Little St. James...";
    } else if (cutsceneTimeline === 1) {
        narrativeText = "Com as provas de corrupção asseguradas, o sinal da transmissão foi reestabelecido.";
    } else if (cutsceneTimeline === 2) {
        narrativeText = "Mais de 3 Terabytes de arquivos confidenciais vazam para redes internacionais.";
    } else if (cutsceneTimeline === 3) {
        narrativeText = "A conspiração caiu por tempo indeterminado. O escândalo agora expõe toda a verdade.";
    } else if (cutsceneTimeline === 4) {
        narrativeText = "Você desaparece sob a escuridão do oceano. Caso encerrado.";
    }

    ctx.fillText(narrativeText, canvas.width / 2, canvas.height - 65);

    ctx.fillStyle = '#71717a';
    ctx.font = '9px Courier Prime';
    ctx.fillText("TRANSMISSÃO OPERACIONAL EM PROGRESSO... AGUARDE ENCERRAMENTO", canvas.width / 2, canvas.height - 25);
}

function updateObjectivesUI() {
    const evidenceCollected = items.filter(i => i.type === 'evidence' && i.collected).length;
    const hasPrimary = player.primaryObjectiveCompleted;

    document.getElementById('evidence-count').textContent = `${evidenceCollected}/3`;
    const mobEvCount = document.getElementById('mob-evidence-count');
    if (mobEvCount) mobEvCount.textContent = `${evidenceCollected}/3`;

    const objPrimary = document.getElementById('obj-primary');
    const objEvidence = document.getElementById('obj-evidence');
    const objEscape = document.getElementById('obj-escape');

    if (hasPrimary) {
        objPrimary.className = "flex items-start gap-2 text-green-500 line-through opacity-60";
        objPrimary.querySelector('i').className = "fa-solid fa-square-check text-green-500";
    } else {
        objPrimary.className = "flex items-start gap-2 text-purple-400 font-bold animate-pulse";
        objPrimary.querySelector('i').className = "fa-regular fa-square text-purple-500";
    }

    if (evidenceCollected === 3) {
        objEvidence.className = "flex items-start gap-2 text-green-500 line-through opacity-60";
        objEvidence.querySelector('i').className = "fa-solid fa-square-check text-green-500";
    } else {
        objEvidence.className = "flex items-start gap-2 text-zinc-300";
        objEvidence.querySelector('i').className = "fa-regular fa-square text-zinc-600";
    }

    if (evidenceCollected === 3 && hasPrimary) {
        objEscape.className = "flex items-start gap-2 text-amber-500 font-bold animate-pulse";
        objEscape.querySelector('i').className = "fa-solid fa-circle-arrow-up text-amber-500";

        const boatItem = items.find(i => i.type === 'boat');
        if (boatItem) {
            let dx = player.x - boatItem.x;
            let dy = player.y - boatItem.y;
            if (Math.sqrt(dx*dx + dy*dy) < 60) {
                triggerCutscene();
            }
        }
    } else {
        objEscape.className = "flex items-start gap-2 text-zinc-600 opacity-40";
        objEscape.querySelector('i').className = "fa-regular fa-square text-zinc-800";
    }
}

function updateInventoryUI() {
    const rockInv = document.getElementById('rock-inventory');
    if (rockInv) {
        rockInv.innerHTML = `<i class="fa-solid fa-circle mr-1 text-[8px]"></i> ${player.rockCount} / 3`;
    }
}

function startGame() {
    sound.init();
    sound.startAmbience();

    document.getElementById('start-screen').classList.add('hidden');
    document.getElementById('gameover-screen').classList.add('hidden');
    document.getElementById('victory-screen').classList.add('hidden');

    createIslandMap();

    player.x = 100;
    player.y = 1650;
    player.vx = 0;
    player.vy = 0;
    player.rockCount = 3;
    player.flashlightOn = false;
    player.primaryObjectiveCompleted = false;
    globalAlertLevel = 0;
    highestAlert = 0;

    gameState = 'PLAYING';
    startTime = Date.now();

    updateObjectivesUI();
    updateInventoryUI();
}

function triggerGameOver(reason) {
    gameState = 'GAMEOVER';
    sound.stopAmbience();

    const evCount = items.filter(i => i.type === 'evidence' && i.collected).length;
    document.getElementById('fail-reason').textContent = reason;
    document.getElementById('fail-evidence').textContent = `${evCount} de 3 provas seguras`;
    document.getElementById('gameover-screen').classList.remove('hidden');
}

function triggerVictory() {
    gameState = 'VICTORY';
    finishTime = Date.now();
    sound.stopAmbience();

    let totalSec = Math.floor((finishTime - startTime) / 1000);
    let min = Math.floor(totalSec / 60);
    let sec = totalSec % 60;
    let timeStr = `${min.toString().padStart(2, '0')}:${sec.toString().padStart(2, '0')}`;

    document.getElementById('victory-time').textContent = timeStr;
    document.getElementById('victory-screen').classList.remove('hidden');
}

document.getElementById('choose-pc').addEventListener('click', () => {
    inputDevice = 'PC';
    document.getElementById('sidebar').classList.remove('hidden');
    document.getElementById('sidebar').classList.add('flex');
    document.getElementById('mobile-hud').classList.add('hidden');
    document.getElementById('device-screen').classList.add('hidden');
    
    sound.init();
    setupMultiplayer();
});

document.getElementById('choose-mobile').addEventListener('click', () => {
    inputDevice = 'MOBILE';
    document.getElementById('sidebar').classList.add('hidden');
    document.getElementById('mobile-hud').classList.remove('hidden');
    document.getElementById('device-screen').classList.add('hidden');
    
    sound.init();
    setupMultiplayer();
});

document.querySelectorAll('.color-dot').forEach(btn => {
    btn.addEventListener('click', () => {
        sound.playTick();
        document.querySelectorAll('.color-dot').forEach(b => b.classList.remove('border-white', 'scale-110'));
        btn.classList.add('border-white', 'scale-110');
        myColor = btn.getAttribute('data-color');
    });
});

const firstColorDot = document.querySelector('.color-dot');
if (firstColorDot) {
    firstColorDot.classList.add('border-white', 'scale-110');
    myColor = firstColorDot.getAttribute('data-color');
}

function generateTacticalRoomCode() {
    const prefixes = ["SHADOW", "STRIKE", "VIPER", "GHOST", "RAPTOR", "PHANTOM", "COBRA", "ALPHA", "TEMPEST", "ODIN"];
    const suffixes = ["SQUAD", "FORCE", "ECHO", "BLADE", "SABER", "HAWK", "DELTA", "OMEGA", "NIGHT", "RANGER"];
    const randNum = Math.floor(100 + Math.random() * 900);
    return `${prefixes[Math.floor(Math.random() * prefixes.length)]}-${suffixes[Math.floor(Math.random() * suffixes.length)]}-${randNum}`;
}

// Geração de Códigos Privados
document.getElementById('btn-generate-code').addEventListener('click', () => {
    sound.playTick();
    const newCode = generateTacticalRoomCode();
    
    const displayBox = document.getElementById('generated-code-box');
    const displayLbl = document.getElementById('lbl-generated-code');
    const inputField = document.getElementById('input-custom-room');

    if (displayBox && displayLbl) {
        displayLbl.textContent = newCode;
        displayBox.classList.remove('hidden');
    }
    
    if (inputField) {
        inputField.value = newCode;
    }

    showSystemNotification("Novo código privado gerado!", "fa-solid fa-key", "text-amber-500");
});

// Cópia de Código
document.getElementById('btn-copy-code').addEventListener('click', () => {
    sound.playTick();
    const displayLbl = document.getElementById('lbl-generated-code');
    if (displayLbl && displayLbl.textContent && displayLbl.textContent !== "NENHUM") {
        const success = copyTextToClipboard(displayLbl.textContent);
        if (success) {
            showSystemNotification("Código copiado com sucesso!", "fa-solid fa-circle-check", "text-green-400");
        } else {
            showSystemNotification("Erro ao copiar: " + displayLbl.textContent, "fa-solid fa-circle-exclamation", "text-red-500");
        }
    }
});

// Entrada de código privado
document.getElementById('btn-create-room').addEventListener('click', () => {
    const inputField = document.getElementById('input-custom-room');
    if (inputField && inputField.value.trim()) {
        const customCode = inputField.value.trim().toUpperCase().replace(/[^A-Z0-9_-]/g, "");
        if (customCode.length > 2) {
            window.joinCoopRoom(customCode);
        } else {
            showSystemNotification("Insira um código com mais de 2 letras.", "fa-solid fa-triangle-exclamation", "text-red-500");
        }
    } else {
        showSystemNotification("Gere ou digite um código primeiro.", "fa-solid fa-triangle-exclamation", "text-amber-500");
    }
});

function loop() {
    if (gameState === 'CUTSCENE') {
        updateCutscene();
        drawCutscene();
    } else {
        updateGame();
        drawGame();
    }
    requestAnimationFrame(loop);
}

function resizeCanvas() {
    const rect = canvas.parentNode.getBoundingClientRect();
    
    const targetWidth = Math.max(1, rect.width || 0);
    const targetHeight = Math.max(1, rect.height || 0);

    canvas.width = targetWidth;
    canvas.height = targetHeight;

    if (!offscreenCanvas) {
        offscreenCanvas = document.createElement('canvas');
    }
    offscreenCanvas.width = targetWidth;
    offscreenCanvas.height = targetHeight;
    offscreenCtx = offscreenCanvas.getContext('2d');

    if (gameState === 'CUTSCENE') {
        drawCutscene();
    } else {
        drawGame();
    }
}

window.addEventListener('resize', resizeCanvas);

document.getElementById('start-btn').addEventListener('click', startGame);
document.getElementById('restart-btn').addEventListener('click', startGame);
document.getElementById('play-again-btn').addEventListener('click', startGame);

document.getElementById('audio-toggle-btn').addEventListener('click', () => {
    sound.enabled = !sound.enabled;
    const btn = document.getElementById('audio-icon-btn');
    const txt = document.getElementById('audio-toggle-btn');
    if (sound.enabled) {
        btn.className = "fa-solid fa-volume-high text-amber-500";
        txt.innerHTML = `<i class="fa-solid fa-volume-high text-amber-500" id="audio-icon-btn"></i> Áudio Ativo`;
        sound.init();
        if (gameState === 'PLAYING') sound.startAmbience();
    } else {
        btn.className = "fa-solid fa-volume-xmark text-zinc-500";
        txt.innerHTML = `<i class="fa-solid fa-volume-xmark text-zinc-500" id="audio-icon-btn"></i> Áudio Mudo`;
        sound.stopAmbience();
    }
});

window.onload = function() {
    resizeCanvas();
    initTextures(); 
    createIslandMap();
    loop();
};
</script>
