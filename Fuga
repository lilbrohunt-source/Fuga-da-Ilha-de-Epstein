class Wall {
    constructor(x, y, w, h, type) {
        this.x = x; this.y = y; this.w = w; this.h = h; this.type = type;
    }
    draw() {
        if (this.x + this.w < camera.x - 50 || this.x > camera.x + camera.width + 50 ||
            this.y + this.h < camera.y - 50 || this.y > camera.y + camera.height + 50) return;

        if (this.type === "mansion") {
            ctx.fillStyle = '#1e1b18';
            ctx.strokeStyle = '#c2410c';
        } else if (this.type === "lab") {
            ctx.fillStyle = '#111827';
            ctx.strokeStyle = '#10b981';
        } else if (this.type === "temple") {
            ctx.fillStyle = '#0f172a';
            ctx.strokeStyle = '#2563eb';
        } else {
            ctx.fillStyle = '#18181b';
            ctx.strokeStyle = '#3f3f46';
        }

        ctx.lineWidth = 2.5;
        ctx.fillRect(this.x, this.y, this.w, this.h);
        ctx.strokeRect(this.x, this.y, this.w, this.h);

        ctx.fillStyle = 'rgba(255, 255, 255, 0.03)';
        ctx.fillRect(this.x + 3, this.y + 3, this.w - 6, this.h - 6);
    }
}

function addWall(x, y, w, h, t) { walls.push(new Wall(x, y, w, h, t)); }

class Bush {
    constructor(x, y, r) { this.x = x; this.y = y; this.r = r; }
    draw() {
        if (this.x + this.r < camera.x || this.x - this.r > camera.x + camera.width ||
            this.y + this.r < camera.y || this.y - this.r > camera.y + camera.height) return;

        let grad = ctx.createRadialGradient(this.x, this.y, 4, this.x, this.y, this.r);
        grad.addColorStop(0, '#0c2414');
        grad.addColorStop(0.65, '#06130a');
        grad.addColorStop(1, '#010402');
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.r, 0, Math.PI*2);
        ctx.fill();

        ctx.strokeStyle = 'rgba(16, 185, 129, 0.15)';
        ctx.lineWidth = 1.5;
        ctx.stroke();
    }
}

class Item {
    constructor(id, x, y, type, name) {
        this.id = id; this.x = x; this.y = y; this.type = type; this.name = name; this.collected = false;
        this.pulse = 0;
    }
    draw() {
        if (this.collected) return;
        this.pulse += 0.05;
        let s = 1 + Math.sin(this.pulse) * 0.12;

        ctx.save();
        ctx.translate(this.x, this.y);

        if (this.type === 'evidence') {
            ctx.shadowColor = 'rgba(245, 158, 11, 0.8)';
            ctx.shadowBlur = 12;
            ctx.fillStyle = '#f59e0b';
            ctx.fillRect(-7*s, -7*s, 14*s, 14*s);
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(-3*s, 1*s, 6*s, 4*s);
        } else if (this.type === 'primary') {
            ctx.shadowColor = 'rgba(168, 85, 247, 0.8)';
            ctx.shadowBlur = 12;
            ctx.fillStyle = '#a855f7';
            ctx.beginPath();
            ctx.moveTo(0, -8*s);
            ctx.lineTo(7*s, 4*s);
            ctx.lineTo(-7*s, 4*s);
            ctx.closePath();
            ctx.fill();
        } else if (this.type === 'boat') {
            ctx.shadowColor = 'rgba(16, 185, 129, 0.5)';
            ctx.shadowBlur = 15;
            ctx.fillStyle = '#070a12';
            ctx.beginPath();
            ctx.moveTo(-12, -35);
            ctx.lineTo(12, -35);
            ctx.lineTo(20, 15);
            ctx.lineTo(-20, 15);
            ctx.closePath();
            ctx.fill();
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(-6, -8, 12, 15);
            ctx.fillStyle = '#10b981';
            ctx.beginPath();
            ctx.arc(0, -25, 3.5, 0, Math.PI*2);
            ctx.fill();
        }
        ctx.restore();
    }
}

class Searchlight {
    constructor(x, y, radius, speed, viewDistance) {
        this.x = x; this.y = y; this.radius = radius; this.speed = speed;
        this.angle = 0; this.distance = viewDistance;
        this.focalX = x; this.focalY = y;
    }
    update() {
        this.angle += this.speed;
        this.focalX = this.x + Math.cos(this.angle) * this.distance;
        this.focalY = this.y + Math.sin(this.angle) * this.distance;

        if (gameState !== 'PLAYING') return;
        let dx = player.x - this.focalX;
        let dy = player.y - this.focalY;
        let dist = Math.sqrt(dx*dx + dy*dy);

        if (dist < this.radius - 10 && !player.inBush) {
            globalAlertLevel = Math.min(100, globalAlertLevel + 1.3);
            if (Math.random() < 0.05) {
                sound.playAlertRise();
                triggerScreenShake(10, 2);
                createAlertParticle(player.x, player.y, "HOLOFOTE DETECTADO");
            }
        }
    }
    draw() {
        ctx.fillStyle = '#18181b';
        ctx.fillRect(this.x - 8, this.y - 8, 16, 16);
        ctx.strokeStyle = '#52525b';
        ctx.strokeRect(this.x - 8, this.y - 8, 16, 16);

        ctx.save();
        ctx.strokeStyle = 'rgba(254, 240, 138, 0.03)';
        ctx.lineWidth = 1.5;
        ctx.beginPath();
        ctx.moveTo(this.x, this.y);
        ctx.lineTo(this.focalX, this.focalY);
        ctx.stroke();
        ctx.restore();
    }
}

class SecurityCamera {
    constructor(x, y, baseAngle, minAngle, maxAngle, rotSpeed) {
        this.x = x; this.y = y; this.angle = baseAngle;
        this.minAngle = minAngle; this.maxAngle = maxAngle;
        this.speed = rotSpeed;
        this.viewDistance = 180;
        this.viewAngle = Math.PI / 6;
    }
    update() {
        this.angle += this.speed;
        if (this.angle > this.maxAngle || this.angle < this.minAngle) {
            this.speed = -this.speed;
        }

        if (gameState !== 'PLAYING') return;

        let dx = player.x - this.x;
        let dy = player.y - this.y;
        let dist = Math.sqrt(dx*dx + dy*dy);

        if (dist < this.viewDistance && !player.inBush) {
            let angleToPlayer = Math.atan2(dy, dx);
            let diffAngle = Math.abs(angleToPlayer - this.angle);
            if (diffAngle > Math.PI) diffAngle = Math.PI * 2 - diffAngle;

            if (diffAngle < this.viewAngle) {
                let blocked = false;
                for (let wall of walls) {
                    if (lineIntersectsRect(this.x, this.y, player.x, player.y, wall)) {
                        blocked = true;
                        break;
                    }
                }
                if (!blocked) {
                    globalAlertLevel = Math.min(100, globalAlertLevel + 1.5);
                    if (Math.random() < 0.05) {
                        sound.playAlertRise();
                        createAlertParticle(this.x, this.y, "CÂMERA ATIVA");
                    }
                }
            }
        }
    }
    draw() {
        ctx.save();
        ctx.translate(this.x, this.y);
        ctx.rotate(this.angle);
        ctx.fillStyle = '#27272a';
        ctx.fillRect(-8, -4, 14, 8);
        ctx.fillStyle = '#ef4444';
        ctx.fillRect(5, -1.5, 2, 3);
        ctx.restore();
    }
}

class Guard {
    constructor(x, y, patrolPoints, speed) {
        this.x = x; this.y = y; this.patrolPoints = patrolPoints;
        this.currentPointIdx = 0; this.speed = speed; this.baseSpeed = speed;
        this.angle = 0; this.radius = 13;
        this.state = 'PATROL'; 
        this.targetX = x; this.targetY = y;
        this.investigateTimer = 0;
        this.viewAngle = Math.PI / 4.5;
        this.viewDistance = 200;
        this.alertTimer = 0;
    }

    update() {
        let dxMove = 0;
        let dyMove = 0;

        if (this.state === 'PATROL') {
            let target = this.patrolPoints[this.currentPointIdx];
            this.targetX = target.x; this.targetY = target.y;

            let dx = this.targetX - this.x;
            let dy = this.targetY - this.y;
            let dist = Math.sqrt(dx*dx + dy*dy);

            if (dist < 12) {
                this.currentPointIdx = (this.currentPointIdx + 1) % this.patrolPoints.length;
            } else {
                this.angle = Math.atan2(dy, dx);
                dxMove = Math.cos(this.angle) * this.speed;
                dyMove = Math.sin(this.angle) * this.speed;
            }
        } 
        else if (this.state === 'INVESTIGATING') {
            let dx = this.targetX - this.x;
            let dy = this.targetY - this.y;
            let dist = Math.sqrt(dx*dx + dy*dy);

            if (dist < 12) {
                this.investigateTimer--;
                this.angle += 0.04; 
                if (this.investigateTimer <= 0) {
                    this.state = 'PATROL'; this.speed = this.baseSpeed;
                }
            } else {
                this.angle = Math.atan2(dy, dx);
                dxMove = Math.cos(this.angle) * (this.speed * 1.15);
                dyMove = Math.sin(this.angle) * (this.speed * 1.15);
            }
        } 
        else if (this.state === 'CHASING') {
            this.targetX = player.x; this.targetY = player.y;
            let dx = this.targetX - this.x;
            let dy = this.targetY - this.y;
            this.angle = Math.atan2(dy, dx);
            dxMove = Math.cos(this.angle) * (this.speed * 1.35);
            dyMove = Math.sin(this.angle) * (this.speed * 1.35);

            if (player.inBush && !player.flashlightOn) {
                this.state = 'INVESTIGATING'; this.targetX = player.x; this.targetY = player.y;
                this.investigateTimer = 150;
            }
        }

        if (dxMove !== 0 || dyMove !== 0) {
            moveAndResolve(this, dxMove, dyMove);
        }

        this.checkVisionForPlayer();
    }

    checkVisionForPlayer() {
        if (gameState !== 'PLAYING') return;
        let dx = player.x - this.x;
        let dy = player.y - this.y;
        let dist = Math.sqrt(dx*dx + dy*dy);

        if (dist > this.viewDistance) {
            if (this.alertTimer > 0) this.alertTimer -= 0.4;
            return;
        }

        if (player.inBush && !player.flashlightOn && this.state !== 'CHASING') {
            if (this.alertTimer > 0) this.alertTimer -= 0.4;
            return;
        }

        let angleToPlayer = Math.atan2(dy, dx);
        let diffAngle = Math.abs(angleToPlayer - this.angle);
        if (diffAngle > Math.PI) diffAngle = Math.PI * 2 - diffAngle;

        if (diffAngle < this.viewAngle) {
            let blocked = false;
            for (let wall of walls) {
                if (lineIntersectsRect(this.x, this.y, player.x, player.y, wall)) {
                    blocked = true; 
                    break;
                }
            }
            if (!blocked) {
                let modifier = player.flashlightOn ? 2.3 : 1.0;
                this.alertTimer += 2.2 * modifier;
                if (this.alertTimer > 35 && Math.random() < 0.05) sound.playAlertRise();

                if (this.alertTimer >= 100) {
                    this.alertTimer = 100;
                    if (this.state !== 'CHASING') {
                        this.state = 'CHASING';
                        globalAlertLevel = Math.max(globalAlertLevel, 50);
                        triggerScreenShake(18, 3.5);
                        createAlertParticle(this.x, this.y, "ALVO EXPOSTO!");
                    }
                }
                return;
            }
        }
        if (this.alertTimer > 0) this.alertTimer -= 0.3;
    }

    draw() {
        if (this.x < camera.x - 150 || this.x > camera.x + camera.width + 150 ||
            this.y < camera.y - 150 || this.y > camera.y + camera.height + 150) return;

        if (this.state === 'CHASING') {
            ctx.save();
            ctx.fillStyle = '#ef4444';
            ctx.font = 'bold 15px Courier Prime';
            ctx.fillText("!", this.x - 3, this.y - 20);
            ctx.restore();
        } else if (this.state === 'INVESTIGATING') {
            ctx.save();
            ctx.fillStyle = '#f59e0b';
            ctx.font = 'bold 15px Courier Prime';
            ctx.fillText("?", this.x - 3, this.y - 20);
            ctx.restore();
        }

        ctx.save();
        ctx.translate(this.x, this.y);
        ctx.rotate(this.angle);

        ctx.fillStyle = '#18181b';
        ctx.beginPath();
        ctx.arc(0, 0, this.radius, 0, Math.PI*2);
        ctx.fill();

        ctx.fillStyle = '#3f3f46';
        ctx.fillRect(-2, -this.radius-1, 6, 2);
        ctx.fillRect(-2, this.radius-1, 6, 2);

        ctx.fillStyle = '#ef4444';
        ctx.fillRect(3, -2, 3, 4);
        ctx.restore();
    }
}

function circleRectCollision(cx, cy, radius, rect) {
    let testX = cx; let testY = cy;
    if (cx < rect.x) testX = rect.x;
    else if (cx > rect.x + rect.w) testX = rect.x + rect.w;
    if (cy < rect.y) testY = rect.y;
    else if (cy > rect.y + rect.h) testY = rect.y + rect.h;

    let distX = cx - testX; let distY = cy - testY;
    let distance = Math.sqrt((distX * distX) + (distY * distY));
    return distance <= radius;
}

function moveAndResolve(entity, dx, dy) {
    entity.x += dx;
    for (let wall of walls) {
        if (circleRectCollision(entity.x, entity.y, entity.radius, wall)) {
            let closestX = Math.max(wall.x, Math.min(entity.x, wall.x + wall.w));
            let overlapX = entity.radius - Math.abs(entity.x - closestX);
            if (overlapX > 0) {
                entity.x += entity.x > closestX ? (overlapX + 0.1) : -(overlapX + 0.1);
            }
        }
    }

    entity.y += dy;
    for (let wall of walls) {
        if (circleRectCollision(entity.x, entity.y, entity.radius, wall)) {
            let closestY = Math.max(wall.y, Math.min(entity.y, wall.y + wall.h));
            let overlapY = entity.radius - Math.abs(entity.y - closestY);
            if (overlapY > 0) {
                entity.y += entity.y > closestY ? (overlapY + 0.1) : -(overlapY + 0.1);
            }
        }
    }
}

function lineIntersectsRect(x1, y1, x2, y2, rect) {
    let minX = Math.min(x1, x2);
    let maxX = Math.max(x1, x2);
    let minY = Math.min(y1, y2);
    let maxY = Math.max(y1, y2);
    
    if (maxX < rect.x || minX > rect.x + rect.w || maxY < rect.y || minY > rect.y + rect.h) {
        return false;
    }

    let pad = 0.2;
    let rx = rect.x + pad;
    let ry = rect.y + pad;
    let rw = rect.w - pad * 2;
    let rh = rect.h - pad * 2;

    return lineIntersectsLine(x1, y1, x2, y2, rx, ry, rx + rw, ry) ||
           lineIntersectsLine(x1, y1, x2, y2, rx + rw, ry, rx + rw, ry + rh) ||
           lineIntersectsLine(x1, y1, x2, y2, rx + rw, ry + rh, rx, ry + rh) ||
           lineIntersectsLine(x1, y1, x2, y2, rx, ry + rh, rx, ry);
}

function lineIntersectsLine(x1, y1, x2, y2, x3, y3, x4, y4) {
    let denominator = ((y4 - y3) * (x2 - x1) - (x4 - x3) * (y2 - y1));
    if (denominator === 0) return false; 
    
    let uA = ((x4 - x3) * (y1 - y3) - (y4 - y3) * (x1 - x3)) / denominator;
    let uB = ((x2 - x1) * (y1 - y3) - (y2 - y1) * (x1 - x3)) / denominator;
    return (uA >= 0 && uA <= 1 && uB >= 0 && uB <= 1);
}

class Particle {
    constructor(x, y, vx, vy, color, size, life, text=null) {
        this.x = x; this.y = y; this.vx = vx; this.vy = vy;
        this.color = color; this.size = size; this.life = life; this.maxLife = life;
        this.text = text;
    }
    update() {
        this.x += this.vx; this.y += this.vy; this.life--;
    }
    draw() {
        let alpha = this.life / this.maxLife;
        ctx.save();
        ctx.globalAlpha = alpha;
        if (this.text) {
            ctx.fillStyle = this.color;
            ctx.font = 'bold 10px Courier Prime';
            ctx.fillText(this.text, this.x, this.y);
        } else {
            ctx.fillStyle = this.color;
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.size, 0, Math.PI*2);
            ctx.fill();
        }
        ctx.restore();
    }
}

function createAlertParticle(x, y, txt) {
    particles.push(new Particle(x, y - 20, 0, -0.6, '#f87171', 0, 70, txt));
}

function createRain() {
