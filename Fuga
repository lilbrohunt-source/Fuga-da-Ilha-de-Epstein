    let totalOnline = 1;
    const now = Date.now();
    Object.values(playersInLobby).forEach(p => {
        // Filtra agentes desconectados (sem sinal por mais de 6 segundos)
        if (now - p.lastUpdate < 6000) {
            totalOnline++;
            listContainer.innerHTML += `
