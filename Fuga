                    <span class="text-[9px] text-zinc-400 font-mono">AGENTES: <span class="text-amber-500 font-bold">${roomData.activePlayers}</span></span>
                </button>
            `;
        }
    });
}

window.joinCoopRoom = function(roomId) {
    roomId = roomId.toUpperCase().trim().replace(/[^A-Z0-9_-]/g, "");
    if (!roomId) return;
    
    sound.playTick();
    activeRoomId = roomId;

    const codenameInput = document.getElementById('input-codename');
    if (codenameInput && codenameInput.value.trim()) {
        myCodename = codenameInput.value.trim().toUpperCase();
    }

    // Configura os textos do painel de rádio
    document.getElementById('player-codename').textContent = myCodename;
    document.getElementById('player-codename').style.color = myColor;
    
    document.getElementById('room-indicator').textContent = activeRoomId;
    document.getElementById('room-indicator-box').classList.remove('hidden');
    
    const mobCodename = document.getElementById('mob-codename');
    if (mobCodename) mobCodename.textContent = myCodename;

    const mobIndicator = document.querySelector('.id-indicator-mobile');
    if (mobIndicator) {
        mobIndicator.textContent = activeRoomId;
        mobIndicator.classList.remove('hidden');
    }

    if (isOnline && mqttClient) {
        // Desinscreve de registros anteriores e se inscreve na sala específica ativa
        mqttClient.subscribe(`stjames/coop/rooms/active/${activeRoomId}/+`, (err) => {
            if (err) console.error("Falha ao sintonizar frequência da sala:", err);
        });

        // Loop de atualização de anúncio da sala ativa
        setInterval(() => {
            if (isOnline && activeRoomId) {
                const count = Object.keys(playersInLobby).length + 1;
                mqttClient.publish(`stjames/coop/rooms/registry/${activeRoomId}`, JSON.stringify({ count: count }), { qos: 0 });
            }
        }, 3000);

        showSystemNotification(`Frequência sintonizada em ${activeRoomId}!`, "fa-solid fa-circle-check", "text-green-400");
    }

    // Transiciona da tela de salas para a tela de instruções iniciais
    document.getElementById('room-screen').classList.add('hidden');
    document.getElementById('start-screen').classList.remove('hidden');
};

